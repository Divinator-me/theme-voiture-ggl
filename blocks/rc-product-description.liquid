{% render 'rc-product-description',
  product: closest.product,
  block: block,
  default_livraison: block.settings.default_livraison,
  default_fabrication: block.settings.default_fabrication,
  default_garantie: block.settings.default_garantie
%}

<script src="{{ 'product-rc.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Description produit RC",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Textes par défaut (tous les produits)"
    },
    {
      "type": "paragraph",
      "content": "Ces textes s'affichent sur toutes les fiches produit. Pour un produit spécifique, remplis le metafield RC correspondant dans la fiche produit."
    },
    {
      "type": "richtext",
      "id": "default_livraison",
      "label": "Livraison et retours (défaut)",
      "default": "<p><strong>Livraison</strong></p><ul><li>Livraison offerte en France : 4 à 8 jours ouvrés</li><li>Livraison Suivie et assurée à Domicile avec : Colissimo / DHL / Fedex / Chronopost ou en Point Relai</li></ul><p><strong>Retours</strong></p><ul><li>30 jours pour changer d'avis</li><li>Produit non utilisé, complet et dans son emballage d'origine</li></ul>"
    },
    {
      "type": "richtext",
      "id": "default_fabrication",
      "label": "Fabrication hautement contrôlée (défaut)",
      "default": "<p>Chez RCLAB, on ne vend pas des jouets bas de gamme. Chaque voiture est sélectionnée par des passionnés et contrôlée dans des <strong>ateliers spécialisés</strong> : châssis renforcés, transmissions dimensionnées pour un usage réel, pièces métal aux points critiques (transmission, pignons, ESC), soudures propres, finitions vérifiées avant expédition.</p><p>On fait attention à chaque détail, solidité des pièces, fiabilité de l'électronique, cohérence des performances annoncées, pour que ta machine tienne dans l'herbe, la poussière et les chocs, sortie après sortie.</p><p>Le but : une RC qui roule vraiment, pas un modèle qui casse au bout de deux sessions.</p>"
    },
    {
      "type": "richtext",
      "id": "default_garantie",
      "label": "Retour gratuit (défaut)",
      "default": "<p><strong>↩️ Retour gratuit</strong> sous 30 jours pour changer d'avis.</p><p>Le produit doit être non utilisé, complet et dans son emballage d'origine. Contacte le SAV si besoin.</p>"
    }
  ],
  "presets": [
    {
      "name": "Description produit RC"
    }
  ]
}
{% endschema %}
