{% render 'rc-product-description',
  product: closest.product,
  block: block,
  default_livraison: block.settings.default_livraison,
  default_garantie: block.settings.default_garantie
%}

{% schema %}
{
  "name": "Description produit RC",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Textes par défaut (tous les produits)"
    },
    {
      "type": "paragraph",
      "content": "Livraison et Garantie utilisent ces textes sur tous les produits. Pour un produit spécifique, remplis le metafield RC correspondant dans la fiche produit."
    },
    {
      "type": "richtext",
      "id": "default_livraison",
      "label": "Livraison et retours (défaut)",
      "default": "<p><strong>Livraison</strong></p><ul><li>Livraison offerte en France : 4 à 8 jours</li><li>Livraison Suivie et assurée à Domicile avec : Colissimo / DHL / Fedex / Chronopost ou en Point Relai</li></ul><p><strong>Retours</strong></p><ul><li>30 jours pour changer d'avis</li><li>Produit non utilisé, complet et dans son emballage d'origine</li></ul>"
    },
    {
      "type": "richtext",
      "id": "default_garantie",
      "label": "Garantie 2 ans (défaut)",
      "default": "<p>Tous nos modèles sont couverts par une <strong>garantie 2 ans</strong> sur les défauts de fabrication et les pièces couvertes.</p><p>En cas de problème en usage normal, contacte le SAV avec une photo ou une vidéo. On te guide vers la solution la plus rapide.</p>"
    }
  ],
  "presets": [
    {
      "name": "Description produit RC"
    }
  ]
}
{% endschema %}
