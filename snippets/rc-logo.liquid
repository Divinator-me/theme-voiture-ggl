{%- liquid
  assign logo_modifier = modifier | default: 'nav'
  assign logo_class = 'rc-logo rc-logo--' | append: logo_modifier
  assign logo_theme = theme | default: 'light'

  if logo_theme == 'dark'
    assign logo_asset = 'rclab-logo-dark.png'
  else
    assign logo_asset = 'rclab-logo.png'
  endif
-%}
<img
  class="{{ logo_class }}"
  src="{{ logo_asset | asset_url }}"
  alt="RCLAB"
  width="180"
  height="72"
  loading="eager"
  {% if logo_modifier == 'nav' %}fetchpriority="high"{% endif %}
>
