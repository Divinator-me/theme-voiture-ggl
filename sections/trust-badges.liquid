{{ 'trust-badges.css' | asset_url | stylesheet_tag }}

{% assign badges = '宖囹|Livraison 5-8 jours|Expﾃｩdition rapide depuis notre atelier||宖白|Paiement sﾃｩcurisﾃｩ|Transactions protﾃｩgﾃｩes et cryptﾃｩes||宖町|Conseillers experts|Une ﾃｩquipe RC disponible 7j/7||竊ｩ髹楯Retour 30 jours|Tu testes, tu valides, tu roules' | split: '||' %}

<section class="rc-trust" aria-label="Avantages boutique">
  <div class="rc-trust__grid">
    {% for badge in badges %}
      {% assign parts = badge | split: '|' %}
      <article class="rc-trust__item">
        <span class="rc-trust__icon" aria-hidden="true">{{ parts[0] }}</span>
        <div>
          <h2>{{ parts[1] }}</h2>
          <p>{{ parts[2] }}</p>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "presets": [
    {
      "name": "Trust badges"
    }
  ]
}
{% endschema %}
