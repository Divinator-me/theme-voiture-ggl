{%- liquid
  assign promo_week_seconds = 604800
  assign promo_anchor = '2026-06-29' | date: '%s' | plus: 0
  assign promo_now = 'now' | date: '%s' | plus: 0
  assign promo_diff = promo_now | minus: promo_anchor

  if promo_diff < 0
    assign promo_week_index = 0
  else
    assign promo_week_index = promo_diff | divided_by: promo_week_seconds
  endif

  assign promo_offset = promo_week_index | times: promo_week_seconds
  assign promo_week_start = promo_anchor | plus: promo_offset
  assign promo_week_last_day = promo_week_start | plus: 518400
  assign promo_week_end = promo_week_start | plus: 604799
  assign promo_date_start = promo_week_start | date: '%d/%m'
  assign promo_date_end = promo_week_last_day | date: '%d/%m'
  assign promo_dates_label = 'Du ' | append: promo_date_start | append: ' au ' | append: promo_date_end
-%}

{{ 'promo-bar.css' | asset_url | stylesheet_tag }}
<script src="{{ 'promo-bar.js' | asset_url }}" defer></script>

<section class="rc-promo-bar" aria-label="Offre spéciale">
  <div class="rc-promo-bar__mobile">
    <p class="rc-promo-bar__offer">
      <span aria-hidden="true">🎁</span>
      <strong>Offre spéciale :</strong>
      1 batterie offerte + extension garantie 2 ans
    </p>

    <div class="rc-promo-bar__actions">
      <span class="rc-promo-bar__date">{{ promo_dates_label }}</span>
      <a class="rc-promo-bar__cta" href="{{ routes.all_products_collection_url }}" aria-label="Profiter de l'offre">
        <span class="rc-promo-bar__cta-label">J'en profite<span class="rc-promo-bar__cta-arrow" aria-hidden="true">→</span></span>
      </a>
    </div>
  </div>

  <div class="rc-promo-bar__desktop">
    <span class="rc-promo-bar__origin"><span class="rc-promo-bar__origin-mark" aria-hidden="true">•</span> Entreprise niçoise</span>

    <div class="rc-promo-bar__center">
      <p class="rc-promo-bar__offer">
        <span aria-hidden="true">🎁</span>
        <strong>Offre spéciale :</strong>
        1 batterie offerte + extension garantie 2 ans pour toute voiture RC achetée
      </p>
      <span class="rc-promo-bar__date">{{ promo_dates_label }}</span>
    </div>

    <div class="rc-promo-bar__actions">
      <div
        class="rc-promo-bar__countdown"
        data-promo-countdown
        data-countdown-end="{{ promo_week_end }}"
        aria-live="polite"
      >
        <span class="rc-promo-bar__countdown-part"><b data-days>00</b><small>jours</small></span>
        <span class="rc-promo-bar__countdown-sep" aria-hidden="true">:</span>
        <span class="rc-promo-bar__countdown-part"><b data-hours>00</b><small>heures</small></span>
        <span class="rc-promo-bar__countdown-sep" aria-hidden="true">:</span>
        <span class="rc-promo-bar__countdown-part"><b data-minutes>00</b><small>min</small></span>
        <span class="rc-promo-bar__countdown-sep" aria-hidden="true">:</span>
        <span class="rc-promo-bar__countdown-part"><b data-seconds>00</b><small>sec</small></span>
      </div>

      <a class="rc-promo-bar__cta" href="{{ routes.all_products_collection_url }}" aria-label="Profiter de l'offre">
        <span class="rc-promo-bar__cta-label">J'en profite<span class="rc-promo-bar__cta-arrow" aria-hidden="true">→</span></span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo bar",
  "presets": [
    {
      "name": "Promo bar"
    }
  ]
}
{% endschema %}
