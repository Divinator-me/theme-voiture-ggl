{{ 'footer.css' | asset_url | stylesheet_tag }}

<footer class="rc-footer">
  <div class="rc-footer__top">
    <div class="rc-footer__brand">
      <a href="{{ routes.root_url }}" class="rc-footer__logo" aria-label="Accueil RCLAB">RCLAB</a>
      <p>Voitures RC premium et conseils terrain pour rouler fort, longtemps, et sans galère.</p>
    </div>

    <div class="rc-footer__badge">
      <span>Garantie 2 ans</span>
      <span>Livraison offerte France</span>
    </div>
  </div>

  <div class="rc-footer__grid">
    <nav class="rc-footer__col rc-footer__col--collections" aria-label="Nos collections">
      <h2>Nos collections</h2>
      <a href="{{ routes.collections_url }}/monster-truck">Monster Truck / 4x4</a>
      <a href="{{ routes.collections_url }}/drift">Drift</a>
      <a href="{{ routes.collections_url }}/rallye">Rallye</a>
      <a href="{{ routes.collections_url }}/buggy">Buggy</a>
      <a href="{{ routes.collections_url }}/piste">Piste</a>
      <a href="{{ routes.collections_url }}/crawler">Crawler</a>
    </nav>

    <nav class="rc-footer__col" aria-label="Boutique">
      <h2>Boutique</h2>
      <a href="{{ routes.all_products_collection_url }}">Tous les produits</a>
      <a href="#top-ventes">Meilleures ventes</a>
      <a href="{{ routes.collections_url }}">Toutes les collections</a>
    </nav>

    <nav class="rc-footer__col" aria-label="Aide">
      <h2>Aide</h2>
      <a href="{{ routes.root_url }}#faq">FAQ</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/livraison">Livraison</a>
      <a href="/policies/refund-policy">Retours</a>
      <a href="/policies/privacy-policy">Confidentialité</a>
    </nav>

    <div class="rc-footer__newsletter">
      <h2>Newsletter</h2>
      <p>Des drops, des promos et des conseils de réglage directement dans ta boîte.</p>
      {% form 'customer', class: 'rc-footer__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="rc-footer-email">Adresse email</label>
        <input id="rc-footer-email" type="email" name="contact[email]" placeholder="ton@email.com" required>
        <button type="submit">S'inscrire</button>
      {% endform %}
    </div>
  </div>

  <div class="rc-footer__bottom">
    <p>© 2026 RCLAB. Tous droits réservés.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer RC",
  "presets": [
    {
      "name": "Footer RC"
    }
  ]
}
{% endschema %}
