{{ 'footer.css' | asset_url | stylesheet_tag }}

<footer class="rc-footer">
  <div class="rc-footer__grid">
    <div class="rc-footer__brand">
      <a href="{{ routes.root_url }}" class="rc-footer__logo" aria-label="Accueil RCLAB">RCLAB</a>
      <p>Voitures RC premium, pièces, conseils et sensations fortes pour tous les pilotes.</p>
    </div>

    <nav class="rc-footer__col" aria-label="Boutique">
      <h2>Boutique</h2>
      <a href="{{ routes.all_products_collection_url }}">Monster Truck</a>
      <a href="{{ routes.all_products_collection_url }}">Buggy</a>
      <a href="{{ routes.all_products_collection_url }}">Crawler</a>
      <a href="{{ routes.all_products_collection_url }}">Drift</a>
      <a href="{{ routes.all_products_collection_url }}">Pièces détachées</a>
    </nav>

    <nav class="rc-footer__col" aria-label="Aide">
      <h2>Aide</h2>
      <a href="/pages/faq">FAQ</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/livraison">Livraison</a>
      <a href="/policies/refund-policy">Retours</a>
    </nav>

    <div class="rc-footer__newsletter">
      <h2>Newsletter</h2>
      <p>Des drops, des promos et des conseils de réglage directement dans ta boîte.</p>
      {% form 'customer', class: 'rc-footer__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="rc-footer-email">Adresse email</label>
        <input id="rc-footer-email" type="email" name="contact[email]" placeholder="ton@email.com" required>
        <button type="submit">S'inscrire</button>
      {% endform %}
    </div>
  </div>

  <div class="rc-footer__bottom">
    <p>© 2026 RCLAB. Tous droits réservés.</p>
    <div class="rc-footer__socials" aria-label="Réseaux sociaux">
      <a href="https://www.instagram.com" aria-label="Instagram">Instagram</a>
      <a href="https://www.tiktok.com" aria-label="TikTok">TikTok</a>
      <a href="https://www.youtube.com" aria-label="YouTube">YouTube</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer RC",
  "presets": [
    {
      "name": "Footer RC"
    }
  ]
}
{% endschema %}
