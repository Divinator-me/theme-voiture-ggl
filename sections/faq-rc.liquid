{{ 'faq-rc.css' | asset_url | stylesheet_tag }}

{% assign faqs = 'Quels modèles choisir pour débuter ?|Pour commencer, privilégie une voiture RC robuste, simple à piloter et adaptée à ton terrain: buggy, monster truck ou piste selon ton usage.||Les voitures sont-elles prêtes à rouler ?|Les fiches produits indiqueront clairement si le modèle est RTR, en kit, ou s’il faut ajouter une batterie, un chargeur ou une radio.||Quelle autonomie prévoir ?|Selon le modèle, la batterie et le style de conduite, l’autonomie varie généralement entre 15 et 30 minutes. Nous préciserons les infos produit par produit.||Peut-on rouler dehors ?|Oui, mais il faut choisir la bonne catégorie: monster truck et buggy pour terrains irréguliers, piste et drift pour surfaces lisses.||Les pièces détachées seront-elles disponibles ?|L’objectif est de proposer progressivement les pièces importantes: pneus, batteries, carrosseries, suspensions et éléments d’usure.' | split: '||' %}

<section class="rc-faq" aria-label="Questions fréquentes">
  <div class="rc-faq__inner">
    <div class="rc-faq__header">
      <span>FAQ</span>
      <h2>Questions fréquentes</h2>
    </div>

    <div class="rc-faq__list">
      {% for faq in faqs %}
        {% assign parts = faq | split: '|' %}
        <details class="rc-faq__item" {% if forloop.first %}open{% endif %}>
          <summary>
            <span>{{ parts[0] }}</span>
            <b aria-hidden="true">+</b>
          </summary>
          <p>{{ parts[1] }}</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ RC",
  "presets": [
    {
      "name": "FAQ RC"
    }
  ]
}
{% endschema %}
