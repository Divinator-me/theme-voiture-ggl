{{ 'hero.css' | asset_url | stylesheet_tag }}

<section class="rc-hero" aria-label="Voitures RC en action">
  <div class="rc-hero__background" aria-hidden="true"></div>
  <div class="rc-hero__overlay" aria-hidden="true"></div>

  <div class="rc-hero__content">
    <h1 class="rc-hero__title">
      <span class="rc-hero__title-line rc-hero__title-line--dark">L'adrénaline</span>
      <span class="rc-hero__title-line rc-hero__title-line--light">En miniature</span>
    </h1>

    <div class="rc-hero__product">
      <svg class="rc-hero__car" viewBox="0 0 560 320" role="img" aria-label="Voiture RC monster truck stylisée">
        <path d="M62 190c17-43 54-71 111-80l112-18 66-52h72c29 0 56 14 72 38l44 66h35c18 0 31 14 31 31v36H30v-21h32Z" fill="#0A0A0A" stroke="#FFFFFF" stroke-width="15" stroke-linejoin="round"/>
        <path d="M169 111h180l-57 53H91l78-53Z" fill="#FFFFFF"/>
        <path d="M324 95h94c17 0 33 8 43 22l28 41H324V95Z" fill="#FFFFFF" opacity=".92"/>
        <path d="M83 213h402" fill="none" stroke="#FFFFFF" stroke-width="18" stroke-linecap="round"/>
        <circle cx="130" cy="226" r="53" fill="#0A0A0A" stroke="#FFFFFF" stroke-width="16"/>
        <circle cx="130" cy="226" r="17" fill="#FFFFFF"/>
        <circle cx="428" cy="226" r="53" fill="#0A0A0A" stroke="#FFFFFF" stroke-width="16"/>
        <circle cx="428" cy="226" r="17" fill="#FFFFFF"/>
        <path d="M175 170h150M369 170h80M236 74l29-34M415 41l18-29" fill="none" stroke="#FF2D2D" stroke-width="10" stroke-linecap="round"/>
      </svg>
    </div>

    <a class="rc-hero__cta" href="{{ routes.all_products_collection_url }}">Découvrir</a>

    <div class="rc-hero__carousel" aria-hidden="true">
      <span class="rc-hero__arrow">‹</span>
      <span class="rc-hero__dot"></span>
      <span class="rc-hero__dot"></span>
      <span class="rc-hero__dot rc-hero__dot--active"></span>
      <span class="rc-hero__dot"></span>
      <span class="rc-hero__dot"></span>
      <span class="rc-hero__arrow">›</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero RC",
  "presets": [
    {
      "name": "Hero RC"
    }
  ]
}
{% endschema %}
