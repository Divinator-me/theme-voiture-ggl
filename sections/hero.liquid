{{ 'hero.css' | asset_url | stylesheet_tag }}

<section class="rc-hero" data-hero aria-label="Collection voitures RC 2026">
  <div class="rc-hero__grid" aria-hidden="true"></div>
  <div class="rc-hero__burn" aria-hidden="true"></div>

  <div class="rc-hero__inner">
    <p class="rc-hero__tag">🏆 Collection 2026</p>

    <h1 class="rc-hero__title">
      <span class="rc-hero__line">L'adrénaline</span>
      <span class="rc-hero__line rc-hero__line--outline">En miniature</span>
    </h1>

    <div class="rc-hero__visual">
      <div class="rc-hero__spotlight" aria-hidden="true"></div>
      <div class="rc-hero__carousel" data-hero-carousel aria-label="Voitures RC en vedette">
        <img
          class="rc-hero__image is-active"
          src="{{ 'hero-rc-gtr.png' | asset_url }}"
          alt="Voiture RC Nissan GT-R en studio"
          width="2560"
          height="1468"
          loading="eager"
          fetchpriority="high"
        >
        <img
          class="rc-hero__image"
          src="{{ 'hero-car-conquer.png' | asset_url }}"
          alt="Voiture RC monster truck noire et rouge"
          width="1000"
          height="492"
          loading="eager"
        >
        <img
          class="rc-hero__image"
          src="{{ 'hero-car-crawler.png' | asset_url }}"
          alt="Voiture RC crawler noire et blanche"
          width="1745"
          height="1202"
          loading="eager"
        >
        <img
          class="rc-hero__image"
          src="{{ 'hero-car-drive.png' | asset_url }}"
          alt="Voiture RC monster truck jaune et noire"
          width="1200"
          height="573"
          loading="eager"
        >
      </div>
    </div>

    <a class="rc-hero__cta" href="{{ routes.all_products_collection_url }}">Découvrir la gamme →</a>
    <a class="rc-hero__secondary" href="#top-ventes">Voir les meilleures ventes ↓</a>

    <dl class="rc-hero__stats">
      <div>
        <dt>80</dt>
        <dd>KM/H</dd>
      </div>
      <div>
        <dt>4WD</dt>
        <dd>Transmission</dd>
      </div>
      <div>
        <dt>45MIN</dt>
        <dd>Autonomie</dd>
      </div>
    </dl>
  </div>
</section>

<script>
  (() => {
    const hero = document.currentScript.previousElementSibling;
    const carousel = hero?.querySelector('[data-hero-carousel]');
    const cars = carousel ? [...carousel.querySelectorAll('.rc-hero__image')] : [];

    if (!carousel || cars.length < 2 || carousel.dataset.ready === 'true') return;

    carousel.dataset.ready = 'true';
    carousel.classList.add('is-js-ready');

    let activeIndex = cars.findIndex((car) => car.classList.contains('is-active'));
    activeIndex = activeIndex >= 0 ? activeIndex : 0;
    cars[activeIndex].classList.add('is-active');

    const switchCar = () => {
      const current = cars[activeIndex];
      activeIndex = (activeIndex + 1) % cars.length;
      const next = cars[activeIndex];

      next.classList.remove('is-exiting');
      current.classList.add('is-exiting');
      current.classList.remove('is-active');

      requestAnimationFrame(() => {
        next.classList.add('is-active');
      });

      window.setTimeout(() => {
        current.classList.remove('is-exiting');
      }, 700);
    };

    window.setInterval(switchCar, 4000);
  })();
</script>

{% schema %}
{
  "name": "Hero RC",
  "presets": [
    {
      "name": "Hero RC"
    }
  ]
}
{% endschema %}
