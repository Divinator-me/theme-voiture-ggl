{{ 'hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hero.js' | asset_url }}" defer></script>

<section class="rc-hero" data-hero aria-label="Collection voitures RC 2026">
  <div class="rc-hero__grid" aria-hidden="true"></div>
  <div class="rc-hero__burn" aria-hidden="true"></div>

  <div class="rc-hero__inner">
    <p class="rc-hero__tag">🏆 Collection 2026</p>

    <h1 class="rc-hero__title">
      <span class="rc-hero__line">L'adrénaline</span>
      <span class="rc-hero__line rc-hero__line--outline">En miniature</span>
    </h1>

    <div class="rc-hero__visual">
      <div class="rc-hero__spotlight" aria-hidden="true"></div>
      <div class="rc-hero__carousel" data-hero-carousel aria-label="Voitures RC en vedette">
        <div class="rc-hero__carousel-track" data-hero-carousel-track>
          <div class="rc-hero__slide">
            <img
              class="rc-hero__image"
              src="{{ 'hero-rc-gtr.png' | asset_url }}"
              alt="Voiture RC Nissan GT-R en studio"
              width="2560"
              height="1468"
              loading="eager"
              fetchpriority="high"
            >
          </div>
          <div class="rc-hero__slide">
            <img
              class="rc-hero__image"
              src="{{ 'hero-car-conquer.png' | asset_url }}"
              alt="Voiture RC monster truck noire et rouge"
              width="1000"
              height="492"
              loading="eager"
            >
          </div>
          <div class="rc-hero__slide rc-hero__slide--crawler">
            <img
              class="rc-hero__image"
              src="{{ 'hero-car-crawler.png' | asset_url }}"
              alt="Voiture RC crawler noire et blanche"
              width="1745"
              height="1202"
              loading="eager"
            >
          </div>
          <div class="rc-hero__slide">
            <img
              class="rc-hero__image"
              src="{{ 'hero-car-drive.png' | asset_url }}"
              alt="Voiture RC monster truck jaune et noire"
              width="1200"
              height="573"
              loading="eager"
            >
          </div>
          <div class="rc-hero__slide" aria-hidden="true">
            <img
              class="rc-hero__image"
              src="{{ 'hero-rc-gtr.png' | asset_url }}"
              alt=""
              width="2560"
              height="1468"
              loading="eager"
              data-hero-clone
            >
          </div>
        </div>
      </div>
    </div>

    <a class="rc-hero__cta" href="#top-ventes">
      <span class="rc-hero__cta-label">Voir les Meilleures Ventes<span class="rc-hero__cta-arrow" aria-hidden="true"> →</span></span>
    </a>

    <dl class="rc-hero__stats">
      <div>
        <dt>85</dt>
        <dd>KM/H</dd>
      </div>
      <div>
        <dt>30MIN</dt>
        <dd>Autonomie</dd>
      </div>
      <div>
        <dt>3-99</dt>
        <dd>Âge rec.</dd>
      </div>
    </dl>
  </div>
</section>

{% schema %}
{
  "name": "Hero RC",
  "presets": [
    {
      "name": "Hero RC"
    }
  ]
}
{% endschema %}
