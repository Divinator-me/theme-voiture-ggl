{{ 'main-nav.css' | asset_url | stylesheet_tag }}
<script src="{{ 'main-nav.js' | asset_url }}" defer></script>

{% assign logo_text = 'RCLAB' %}

<section class="rc-main-nav" data-main-nav aria-label="Navigation principale">
  <a class="rc-main-nav__logo" href="{{ routes.root_url }}" aria-label="Accueil {{ logo_text }}">{{ logo_text }}</a>

  <form class="rc-main-nav__search" action="{{ routes.search_url }}" method="get" role="search">
    <label class="visually-hidden" for="rc-main-nav-search">Rechercher</label>
    <input
      id="rc-main-nav-search"
      type="search"
      name="q"
      placeholder="Rechercher une voiture RC..."
      autocomplete="off"
    >
    <button type="submit" aria-label="Lancer la recherche">→</button>
  </form>

  <nav class="rc-main-nav__actions" aria-label="Actions rapides">
    <button class="rc-main-nav__search-toggle" type="button" data-search-open aria-controls="rc-search-overlay" aria-expanded="false" aria-label="Ouvrir la recherche">⌕</button>
    <a class="rc-main-nav__pill rc-main-nav__pill--outline" href="{{ routes.all_products_collection_url }}">Nouveautés</a>
    <a class="rc-main-nav__pill rc-main-nav__pill--dark" href="{{ routes.all_products_collection_url }}">Promos 🔥</a>
    <a class="rc-main-nav__icon" href="/pages/wishlist" aria-label="Wishlist">♡</a>
    <a class="rc-main-nav__icon rc-main-nav__cart" href="{{ routes.cart_url }}" aria-label="Panier">
      <span>🛒</span>
      <b>{{ cart.item_count | default: 0 }}</b>
    </a>
  </nav>

  <div class="rc-search-overlay" id="rc-search-overlay" data-search-overlay aria-hidden="true">
    <form class="rc-search-overlay__form" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="rc-search-overlay-input">Rechercher</label>
      <input
        id="rc-search-overlay-input"
        type="search"
        name="q"
        placeholder="Rechercher une voiture RC..."
        autocomplete="off"
        data-search-input
      >
      <button type="submit" aria-label="Lancer la recherche">→</button>
      <button type="button" data-search-close aria-label="Fermer la recherche">×</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Main nav",
  "presets": [
    {
      "name": "Main nav"
    }
  ]
}
{% endschema %}
