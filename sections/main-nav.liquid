{{ 'main-nav.css' | asset_url | stylesheet_tag }}
{{ 'rclab-logo.css' | asset_url | stylesheet_tag }}
<script src="{{ 'main-nav.js' | asset_url }}" defer></script>

<section class="rc-main-nav" data-main-nav aria-label="Navigation principale">
  <div class="rc-main-nav__mobile">
    <div class="rc-main-nav__side rc-main-nav__side--left">
      <button class="rc-main-nav__button" type="button" data-menu-open aria-controls="rc-menu-overlay" aria-expanded="false" aria-label="Ouvrir le menu">
        <svg width="24" height="18" viewBox="0 0 24 18" fill="none" xmlns="http://www.w3.org/2000/svg" class="burger-icon" aria-hidden="true">
          <line x1="1" y1="1.5" x2="23" y2="1.5" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="1" y1="9" x2="13" y2="9" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="1" y1="16.5" x2="23" y2="16.5" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <button class="rc-main-nav__button" type="button" data-search-open aria-controls="rc-search-overlay" aria-expanded="false" aria-label="Ouvrir la recherche">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="search-icon" aria-hidden="true">
          <circle cx="9" cy="9" r="7" stroke="#0A0A0A" stroke-width="1.5"/>
          <line x1="14.5" y1="14.5" x2="18.5" y2="18.5" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <a class="rc-main-nav__brand" href="{{ routes.root_url }}" aria-label="Accueil RCLAB">
      {% render 'rc-logo', modifier: 'nav' %}
    </a>

    <nav class="rc-main-nav__side rc-main-nav__side--right" aria-label="Actions rapides">
      <a class="rc-main-nav__button" href="/pages/wishlist" aria-label="Wishlist">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.8 4.6c-1.8-1.7-4.7-1.7-6.5.1L12 7l-2.3-2.3c-1.8-1.8-4.7-1.8-6.5-.1-1.9 1.8-2 4.9-.1 6.8L12 20l8.9-8.6c1.9-1.9 1.8-5-.1-6.8Z"></path>
        </svg>
      </a>
      <a class="rc-main-nav__button rc-main-nav__cart" href="{{ routes.cart_url }}" data-rc-cart-open aria-label="Panier">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6h15l-2 8H8L6 3H3"></path>
          <circle cx="9" cy="20" r="1.5"></circle>
          <circle cx="18" cy="20" r="1.5"></circle>
        </svg>
        <b data-rc-cart-count>{{ cart.item_count | default: 0 }}</b>
      </a>
    </nav>
  </div>

  <div class="rc-main-nav__desktop">
    <a class="rc-main-nav__brand rc-main-nav__brand--desktop" href="{{ routes.root_url }}" aria-label="Accueil RCLAB">
      {% render 'rc-logo', modifier: 'nav' %}
    </a>

    <form class="rc-main-nav__search" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="rc-main-nav-search">Rechercher</label>
      <span class="rc-main-nav__search-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
          <line x1="14.5" y1="14.5" x2="18.5" y2="18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <input id="rc-main-nav-search" type="search" name="q" placeholder="Rechercher une voiture RC..." autocomplete="off">
      <button type="submit" class="rc-main-nav__search-submit" aria-label="Lancer la recherche">
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="m9 5 3 3-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>

    <nav class="rc-main-nav__side rc-main-nav__side--right rc-main-nav__side--desktop" aria-label="Actions rapides">
      <a class="rc-main-nav__button" href="/pages/wishlist" aria-label="Wishlist">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.8 4.6c-1.8-1.7-4.7-1.7-6.5.1L12 7l-2.3-2.3c-1.8-1.8-4.7-1.8-6.5-.1-1.9 1.8-2 4.9-.1 6.8L12 20l8.9-8.6c1.9-1.9 1.8-5-.1-6.8Z"></path>
        </svg>
      </a>
      <a class="rc-main-nav__button rc-main-nav__cart" href="{{ routes.cart_url }}" data-rc-cart-open aria-label="Panier">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6h15l-2 8H8L6 3H3"></path>
          <circle cx="9" cy="20" r="1.5"></circle>
          <circle cx="18" cy="20" r="1.5"></circle>
        </svg>
        <b data-rc-cart-count>{{ cart.item_count | default: 0 }}</b>
      </a>
    </nav>
  </div>

  <div class="rc-menu-overlay" id="rc-menu-overlay" data-menu-overlay aria-hidden="true">
    <div class="rc-menu-overlay__panel" role="dialog" aria-modal="true" aria-label="Menu principal">
      <div class="rc-menu-overlay__body">
        <div class="rc-menu-overlay__head">
          <a class="rc-menu-overlay__logo" href="{{ routes.root_url }}" aria-label="Accueil RCLAB">
            {% render 'rc-logo', modifier: 'menu' %}
          </a>
          <button class="rc-menu-overlay__close" type="button" data-menu-close aria-label="Fermer le menu">×</button>
        </div>
        <nav class="rc-menu-overlay__links" aria-label="Menu mobile">
          <a class="rc-menu-overlay__link" href="{{ routes.root_url }}">
            <span>Accueil</span>
            <span class="rc-menu-overlay__chevron" aria-hidden="true"></span>
          </a>

          <details class="rc-menu-overlay__group" open>
            <summary class="rc-menu-overlay__link rc-menu-overlay__link--toggle">
              <span>Voitures télécommandées</span>
              <span class="rc-menu-overlay__chevron rc-menu-overlay__chevron--toggle" aria-hidden="true"></span>
            </summary>
            <div class="rc-menu-overlay__sub">
              {% render 'rc-nav-collections', context: 'menu' %}
            </div>
          </details>

          <a class="rc-menu-overlay__link" href="{{ routes.root_url }}#top-ventes">
            <span>Meilleures ventes</span>
            <span class="rc-menu-overlay__chevron" aria-hidden="true"></span>
          </a>

          <a class="rc-menu-overlay__link" href="{{ routes.all_products_collection_url }}">
            <span>Tous les produits</span>
            <span class="rc-menu-overlay__chevron" aria-hidden="true"></span>
          </a>

          <a class="rc-menu-overlay__link" href="/pages/qui-sommes-nous">
            <span>Qui sommes-nous ?</span>
            <span class="rc-menu-overlay__chevron" aria-hidden="true"></span>
          </a>

          <details class="rc-menu-overlay__group">
            <summary class="rc-menu-overlay__link rc-menu-overlay__link--toggle">
              <span>Centre d'aide</span>
              <span class="rc-menu-overlay__chevron rc-menu-overlay__chevron--toggle" aria-hidden="true"></span>
            </summary>
            <div class="rc-menu-overlay__sub">
              <a href="/apps/parcelpanel">Suivre ma Commande</a>
            </div>
          </details>
        </nav>
      </div>

      <nav class="rc-menu-overlay__footer" aria-label="Liens rapides">
        <a href="{{ routes.account_url }}">Mon compte</a>
        <a href="/pages/contact">Contact</a>
        <a href="{{ routes.root_url }}#faq">FAQ</a>
        <a href="/apps/parcelpanel">Livraison</a>
      </nav>
    </div>
  </div>

  <div class="rc-search-overlay" id="rc-search-overlay" data-search-overlay aria-hidden="true">
    <form class="rc-search-overlay__form" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="rc-search-overlay-input">Rechercher</label>
      <input
        id="rc-search-overlay-input"
        type="search"
        name="q"
        placeholder="Rechercher une voiture RC..."
        autocomplete="off"
        data-search-input
      >
      <button type="submit" aria-label="Lancer la recherche"><span class="rc-search-overlay__icon" aria-hidden="true">→</span></button>
      <button type="button" data-search-close aria-label="Fermer la recherche"><span class="rc-search-overlay__icon" aria-hidden="true">×</span></button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Main nav",
  "presets": [
    {
      "name": "Main nav"
    }
  ]
}
{% endschema %}
