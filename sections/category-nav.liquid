{{ 'category-nav.css' | asset_url | stylesheet_tag }}

{% assign links = 'MONSTER TRUCK|BUGGY|RALLYE|CRAWLER|DRIFT|PISTE|PIﾃ唎ES Dﾃ欝ACHﾃ右S' | split: '|' %}

<section class="rc-category-nav" aria-label="Catﾃｩgories voitures RC">
  <nav class="rc-category-nav__inner">
    <button
      type="button"
      class="rc-category-nav__menu"
      data-menu-open
      aria-controls="rc-menu-overlay"
      aria-expanded="false"
      aria-label="Ouvrir le menu"
    >
      <span aria-hidden="true">笘ｰ</span> Menu
    </button>
    {% for label in links %}
      <a href="{{ routes.all_products_collection_url }}">{{ label }}</a>
    {% endfor %}
  </nav>
</section>

{% schema %}
{
  "name": "Category nav",
  "presets": [
    {
      "name": "Category nav"
    }
  ]
}
{% endschema %}
