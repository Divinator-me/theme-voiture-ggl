{{ 'category-nav.css' | asset_url | stylesheet_tag }}

{% assign links = 'Monster Truck / 4x4|monster-truck||Buggy|buggy||Rallye / Trophy Truck|rallye||Crawler|crawler||Drift|drift||Piste|piste||Pièces détachées|all' | split: '||' %}

<section class="rc-category-nav" aria-label="Catégories voitures RC">
  <nav class="rc-category-nav__inner">
    <button
      type="button"
      class="rc-category-nav__menu"
      data-menu-open
      aria-controls="rc-menu-overlay"
      aria-expanded="false"
      aria-label="Ouvrir le menu"
    >
      <span aria-hidden="true">☰</span> Menu
    </button>

    {% for link in links %}
      {% assign parts = link | split: '|' %}
      {% assign label = parts[0] %}
      {% assign handle = parts[1] %}
      {% if handle == 'all' %}
        {% assign href = routes.all_products_collection_url %}
      {% else %}
        {% assign href = routes.collections_url | append: '/' | append: handle %}
      {% endif %}
      <a href="{{ href }}">{{ label }}</a>
    {% endfor %}
  </nav>
</section>

{% schema %}
{
  "name": "Category nav",
  "presets": [
    {
      "name": "Category nav"
    }
  ]
}
{% endschema %}
