{{ 'category-nav.css' | asset_url | stylesheet_tag }}

<section class="rc-category-nav" aria-label="Catégories voitures RC">
  <nav class="rc-category-nav__inner">
    <button class="rc-category-nav__menu" type="button" data-menu-open aria-controls="rc-menu-overlay" aria-label="Ouvrir le menu">
      <span aria-hidden="true">☰</span> Menu
    </button>
    {% render 'rc-collection-links', style: 'category-nav' %}
  </nav>
</section>

{% schema %}
{
  "name": "Category nav",
  "presets": [
    {
      "name": "Category nav"
    }
  ]
}
{% endschema %}
