{{ 'contact-rc.css' | asset_url | stylesheet_tag }}

<section class="rc-contact" aria-label="Contact RCLAB">
  <div class="rc-contact__inner">
    <header class="rc-contact__header">
      <span class="rc-contact__badge">Support</span>
      <h1>Contact</h1>
    </header>

    <div class="rc-contact__service">
      <p class="rc-contact__lead">Service client Français</p>

      <ul class="rc-contact__meta">
        <li class="rc-contact__meta-item">
          <span class="rc-contact__meta-value">Lun.–Ven.</span>
          <span class="rc-contact__meta-label">Jours</span>
        </li>
        <li class="rc-contact__meta-item" aria-hidden="true">
          <span class="rc-contact__meta-divider"></span>
        </li>
        <li class="rc-contact__meta-item">
          <span class="rc-contact__meta-value">9h–17h</span>
          <span class="rc-contact__meta-label">Horaires SAV</span>
        </li>
      </ul>

      <p class="rc-contact__timezone">Fuseau horaire : {% render 'rc-timezone-fr' %}</p>

      <p class="rc-contact__channels">
        <a href="mailto:support@rclab-car.com">support@rclab-car.com</a>
        ·
        <a href="tel:+33756884492">07 56 88 44 92</a>
        ·
        chat en direct
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact RCLAB",
  "presets": [
    {
      "name": "Contact RCLAB"
    }
  ]
}
{% endschema %}
