{{ 'categories-grid.css' | asset_url | stylesheet_tag }}

{% assign categories = 'Monster truck / 4x4|category-monster-truck.png|/collections/monster-truck|Bestseller||Drift|category-drift.png|/collections/drift|13 voitures||Rallye|category-rallye.png|/collections/rallye|9 voitures||Buggy|category-buggy.png|/collections/buggy|11 voitures||Piste|category-piste.png|/collections/piste|7 voitures||Dresses|category-dresses.png|/collections/dresses|Nouveau' | split: '||' %}

<section class="rc-categories" aria-label="Collections voitures RC">
  <div class="rc-categories__header">
    <p class="rc-categories__pill">
      <svg width="16" height="12" viewBox="0 0 16 12" fill="none" aria-hidden="true">
        <line x1="1" y1="1" x2="15" y2="1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="1" y1="6" x2="10" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="1" y1="11" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span>Nos collections</span>
    </p>
    <p class="rc-categories__hint">
      <span class="rc-categories__hint-arrow" aria-hidden="true">→</span>
      Glissez pour explorer
    </p>
  </div>

  <div class="rc-categories__track" tabindex="0" aria-label="Carrousel collections">
    {% for category in categories %}
      {% assign parts = category | split: '|' %}
      <a class="rc-category-card" href="{{ parts[2] }}" aria-label="Découvrir la collection {{ parts[0] }}">
        <img
          class="rc-category-card__image"
          src="{{ parts[1] | asset_url }}"
          alt=""
          width="363"
          height="194"
          loading="lazy"
        >
        <span class="rc-category-card__shade" aria-hidden="true"></span>
        <span class="rc-category-card__badge">{{ parts[3] }}</span>
        <span class="rc-category-card__content">
          <span class="rc-category-card__title">{{ parts[0] }}</span>
          <span class="rc-category-card__cta">
            <span>Découvrir</span>
            <b aria-hidden="true">→</b>
          </span>
        </span>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Categories grid",
  "presets": [
    {
      "name": "Categories grid"
    }
  ]
}
{% endschema %}
