<!doctype html>
{%- liquid
  assign rc_redirect_frontpage_collection = false
  if template.name == 'collection' and collection.handle == 'frontpage' and request.design_mode == false
    assign rc_redirect_frontpage_collection = true
  endif
-%}
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    <meta name="google-site-verification" content="pskfJiRxMrbi6G3zY9AI6Up0jictfr8H2EMGf_eWVjg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    >
    {{ 'design-tokens.css' | asset_url | stylesheet_tag }}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-palette' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    {%- if template.name == 'page' and page.handle == 'contact' -%}
      <style>
        .rc-contact__service { display: none !important; }
        .rc-contact__header:not(:has(.rc-contact__intro))::after {
          display: block;
          max-width: 36ch;
          margin: 16px auto 0;
          color: #737373;
          font-size: 15px;
          font-weight: 500;
          line-height: 1.5;
          content: "Service client français — on te répond sous 1 à 2 jours ouvrés.";
        }
      </style>
    {%- endif -%}

    {%- if rc_redirect_frontpage_collection -%}
      <meta http-equiv="refresh" content="0;url={{ routes.root_url }}">
      <meta name="robots" content="noindex, follow">
      <link rel="canonical" href="{{ shop.url }}{{ routes.root_url }}">
    {%- endif -%}
  </head>

  <body class="template-{{ template.name }} page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}

    {% render 'chat-drawer' %}

    <div class="page-wrapper">
      <div id="rc-header-group">
        {% sections 'rc-header-group' %}
      </div>

      <main
        id="MainContent"
        class="content-for-layout"
        role="main"
        data-page-transition-enabled="{{ settings.page_transition_enabled }}"
        data-product-transition="{{ settings.transition_to_main_product }}"
        data-template="{{ template }}"
      >
        {%- if rc_redirect_frontpage_collection -%}
          <script>window.location.replace({{ routes.root_url | json }});</script>
        {%- else -%}
          {{ content_for_layout }}
        {%- endif -%}
      </main>

      <footer id="rc-footer-group">
        {% sections 'rc-footer-group' %}
      </footer>
    </div>

    {% render 'cart-drawer', render_wrapper: true %}
    {% render 'theme-drawer' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
